
PORT=5000

JWT_SECRET=your_jwt_secret

AI_SERVICE_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

NEON_DATABASE_URL=postgresql://neondb_owner:your_password@your_host/your_db?sslmode=verify-full&channel_binding=require
# Optional: database connection pool settings (Neon-friendly defaults)
# Maximum number of connections in the pool
DB_POOL_MAX=10
# Minimum number of idle connections in the pool
DB_POOL_MIN=0
# Maximum time (ms) to wait for a connection to be acquired
DB_POOL_ACQUIRE=10000
# Maximum time (ms) a connection can stay idle before being released
DB_POOL_IDLE=10000

# Go to your Google Account Security settings.
# Enable 2-Step Verification.
# Search for "App Passwords" and create one for "AI Mentor".
# Copy the 16-character code.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_mail@gmail.com
# 16-character app password generated by Google "App Passwords"
SMTP_PASS=your_app_password
FROM_EMAIL=your_mail@gmail.com
FROM_NAME=AI-Mentor
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
